---
import Layout from "../layouts/Layout.astro";

interface Props {
  error: unknown;
}

const { error } = Astro.props;

let errorName = "InternalServerError";
let errorMessage =
  "An unexpected server error occurred while processing this request.";
let errorStack: string | undefined = undefined;

if (error instanceof Error) {
  errorName = error.name;
  errorMessage = error.message;
  errorStack = error.stack;
} else if (error && typeof error === "object") {
  errorName = (error as any).name || errorName;
  errorMessage = (error as any).message || String(error);
  errorStack = (error as any).stack;
} else if (error) {
  errorMessage = String(error);
}

const timestamp =
  new Date().toISOString().replace("T", " ").substring(0, 19) + " UTC";
---

<Layout
  title="500: Server Error — NetSpeed"
  description="An internal server error occurred. Our team has been notified of the telemetry exception."
>
  <main class="flex-1 flex items-center justify-center py-16 px-4 md:px-8">
    <div class="max-w-xl w-full flex flex-col gap-10 text-center md:text-left">
      {/* Visual Error Code and Title Stack */}
      <div class="flex flex-col gap-4">
        <div class="flex justify-center md:justify-start items-center gap-3">
          <span
            class="font-mono text-xs font-semibold px-2 py-0.5 bg-error-soft text-error rounded border border-error/20 uppercase tracking-widest"
          >
            Error 500
          </span>
          <span class="w-1.5 h-1.5 rounded-full bg-error animate-pulse"></span>
        </div>
        <h1
          class="text-4xl md:text-5xl font-semibold tracking-tighter text-ink font-sans leading-tight"
        >
          An unexpected error occurred.
        </h1>
        <p class="text-sm md:text-base text-body leading-relaxed max-w-lg">
          The server encountered an error while processing this request. This
          could be due to a transient connection failure or a backend exception.
        </p>
      </div>

      {/* Action Buttons Row */}
      <div
        class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start"
      >
        <button
          onclick="window.location.reload()"
          class="bg-primary text-on-primary font-medium text-sm rounded-full py-2.5 px-6 hover:opacity-90 active:scale-95 transition-all text-center select-none cursor-pointer flex items-center justify-center gap-2"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H18"></path>
          </svg>
          Reload page
        </button>
        <a
          href="/"
          class="bg-canvas border border-hairline hover:border-hairline-strong text-ink font-medium text-sm rounded-full py-2.5 px-6 active:scale-95 transition-all text-center select-none cursor-pointer inline-flex items-center justify-center"
        >
          Go back home
        </a>
      </div>

      {/* Developer System Diagnostics Block */}
      <div class="flex flex-col gap-2.5 text-left">
        <div class="flex items-center justify-between px-1">
          <span
            class="font-mono text-[10px] uppercase tracking-wider text-mute block"
          >
            System Diagnostics
          </span>
          <span class="font-mono text-[9px] text-mute">
            NETSPEED_SERVER_CRASH_TELEMETRY
          </span>
        </div>

        <div
          class="relative rounded-lg border border-hairline bg-canvas-soft-2 p-5 font-mono text-xs text-body overflow-x-auto shadow-xs"
        >
          {/* Header dots style decoration */}
          <div class="flex gap-1.5 mb-3 opacity-60">
            <span class="w-2.5 h-2.5 rounded-full bg-hairline-strong"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-hairline-strong"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-hairline-strong"></span>
          </div>

          <div class="flex flex-col gap-1.5 whitespace-pre font-mono">
            <div>
              <span class="text-mute font-semibold">ERROR_TYPE :</span>
              <span class="text-ink select-all">{errorName}</span>
            </div>
            <div class="whitespace-normal break-words">
              <span class="text-mute font-semibold">MESSAGE :</span>
              <span class="text-ink select-all">{errorMessage}</span>
            </div>
            <div>
              <span class="text-mute font-semibold">TIMESTAMP :</span>
              <span class="text-ink select-all">{timestamp}</span>
            </div>
            <div>
              <span class="text-mute font-semibold">STATUS :</span>
              <span class="text-error font-semibold"
                >500_INTERNAL_SERVER_ERROR</span>
            </div>
          </div>

          {/* Call Stack section (collapsible) */}
          <details
            class="mt-4 border-t border-hairline pt-3 cursor-pointer group"
          >
            <summary
              class="font-semibold text-mute select-none hover:text-ink transition-colors flex items-center gap-1.5"
            >
              <span>View Call Stack</span>
              <svg
                class="w-3.5 h-3.5 transform group-open:rotate-180 transition-transform duration-200"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <pre
              class="mt-3 text-[10px] text-mute max-h-60 overflow-y-auto leading-relaxed select-all border-l-2 border-hairline pl-3 font-mono whitespace-pre-wrap">{errorStack || "No call stack trace is available."}</pre>
          </details>
        </div>
      </div>
    </div>
  </main>
</Layout>
