---
import SpeedTest from "../components/SpeedTest";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	{/* Sticky Top Header Navigation */}
	<header
		class="sticky top-0 bg-canvas/80 backdrop-blur-md border-b border-hairline h-16 flex items-center z-50"
	>
		<div
			class="w-full max-w-7xl mx-auto px-4 md:px-8 flex justify-between items-center"
		>
			<div class="flex items-center gap-6">
				{/* Modern logo placeholder */}
				<div class="flex items-center gap-2">
					<img
						src="favicon.svg"
						alt="Company Logo"
						width="40"
						height="40"
					/>
					<span
						class="font-bold tracking-tight text-sm font-sans text-ink"
						>NetSpeed</span
					>
				</div>
				<nav class="hidden md:flex items-center gap-4">
					<span
						class="text-xs font-mono bg-canvas-soft-2 px-2.5 py-1 rounded border border-hairline text-mute"
						>v1.0.0-edge</span
					>
				</nav>
			</div>
			<div class="flex items-center gap-4">
				<div
					class="flex items-center gap-3 bg-canvas border border-hairline px-3.5 py-1.5 rounded-full shadow-xs"
				>
					<div
						id="header-server-info"
						class="text-xs font-mono text-mute flex items-center gap-2 select-none"
					>
						<span
							id="server-status-dot"
							class="w-1.5 h-1.5 rounded-full bg-mute animate-pulse"
						></span>
						<span id="server-status-text">Server: Detecting…</span>
					</div>

					<div class="h-3 w-px bg-hairline"></div>

					<button
						id="header-theme-toggle"
						class="text-mute hover:text-ink active:scale-90 transition-[color,transform] duration-150 cursor-pointer flex items-center justify-center select-none"
						title="Switch Theme"
						aria-label="Toggle dark mode"
					>
						{/* Sun icon for light mode (hidden in dark mode) */}
						<svg
							id="sun-icon"
							class="w-3.5 h-3.5 fill-none stroke-current block dark:hidden"
							viewBox="0 0 24 24"
							stroke-width="2"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"
							></path>
						</svg>
						{/* Moon icon for dark mode (hidden in light mode) */}
						<svg
							id="moon-icon"
							class="w-3.5 h-3.5 fill-none stroke-current hidden dark:block"
							viewBox="0 0 24 24"
							stroke-width="2"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
							></path>
						</svg>
					</button>
				</div>
			</div>
		</div>
	</header>

	{/* Main Speed Test Island */}
	<main class="flex-1 flex flex-col justify-center">
		<SpeedTest client:load />
	</main>

	{/* Detailed On-Page SEO Guide & Information */}
	<section id="seo-content-section" class="border-t border-hairline bg-canvas-soft-2 py-16 relative overflow-hidden">
		<div class="max-w-4xl mx-auto px-4 md:px-8">
			<div class="flex flex-col gap-8">
				
				<div class="flex flex-col gap-3">
					<span class="font-mono text-xs uppercase tracking-wider text-mute block" id="seo-eyebrow">
						Expert Insights & Documentation
					</span>
					<h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-ink font-sans" id="seo-heading">
						Understanding Your Connection with our Network Speed Test Tool
					</h2>
					<p class="text-sm md:text-base text-body leading-relaxed max-w-3xl">
						In today's hyper-connected digital landscape, having a reliable internet connection is paramount. Whether you are gaming, working remotely, streaming 4K content, or managing cloud deployments, knowing your network's actual capability is essential. Our state-of-the-art <strong>network speed test tool</strong> provides precise, edge-optimized telemetry of your bandwidth and latency performance. With this advanced <strong>online network speed test</strong>, you can instantly check and diagnose your throughput with zero overhead. For an accurate <strong>network speed test online</strong>, our tool communicates directly with the nearest edge servers.
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-hairline pt-8">
					<div class="flex flex-col gap-4">
						<h3 class="text-lg font-semibold tracking-tight text-ink font-sans" id="seo-subheading-1">
							Why You Should Run a Network Speed Test
						</h3>
						<p class="text-xs md:text-sm text-body leading-relaxed">
							When you choose to <strong>run network speed test</strong> operations, you gain access to vital metrics that define your digital experience. A standard <strong>netspeed check</strong> goes beyond simple download figures; it analyzes latency, jitter, and packet loss under simulated loaded conditions. If you experience buffering while streaming or lag during video calls, checking your <strong>netspeed internet</strong> with a trusted <strong>netspeed monitor</strong> is the first step in troubleshooting.
						</p>
						<p class="text-xs md:text-sm text-body leading-relaxed">
							Using our <strong>best network speed test</strong>, you can measure:
						</p>
						<ul class="list-disc pl-5 text-xs md:text-sm text-body flex flex-col gap-1">
							<li><strong>download speed test</strong>: The rate at which data is pulled from edge servers to your device.</li>
							<li><strong>upload speed test</strong>: The rate at which your device transmits data back.</li>
							<li><strong>Latency & Jitter</strong>: The round-trip time of data transmission.</li>
						</ul>
					</div>

					<div class="flex flex-col gap-4">
						<h3 class="text-lg font-semibold tracking-tight text-ink font-sans" id="seo-subheading-2">
							Assessing Different Connection Types
						</h3>
						<p class="text-xs md:text-sm text-body leading-relaxed">
							Internet quality varies significantly depending on the medium. If you are connected to local routing, conducting a <strong>wifi network speed test</strong> helps verify if your router is experiencing physical obstruction or channel interference. Comparing a <strong>wifi speed test</strong> to a wired Ethernet test reveals the efficiency of your internal wireless setup. With our <strong>network speed test wifi</strong> capabilities, you can walk around your office or home to find cellular and wireless dead zones.
						</p>
						<p class="text-xs md:text-sm text-body leading-relaxed">
							For users on specialized service providers, such as commercial edge routing or residential coaxial lines, checking against a <strong>spectrum speed test</strong> or standard <strong>netspeed test</strong> helps verify that your ISP is delivering the bandwidth promised in your service plan. If you are asking yourself: "How do I perform <strong>my network speed test</strong> accurately?" the answer lies in edge execution. Unlike traditional tools, our engine leverages concurrent pipes and zero browser caching to ensure your ISP cannot artificially compress or throttle your results during the benchmark.
						</p>
					</div>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-hairline pt-8">
					<div class="flex flex-col gap-4">
						<h3 class="text-lg font-semibold tracking-tight text-ink font-sans" id="seo-subheading-3">
							Inside the Technology of Go Netspeed Engine
						</h3>
						<p class="text-xs md:text-sm text-body leading-relaxed">
							The technology behind the <strong>go netspeed</strong> engine is designed with maximum precision. Traditional platforms perform a basic <strong>net speed test</strong> by fetching static files, which can lead to skewed results due to regional content delivery network (CDN) caches. Our <strong>speed test</strong> uses real-time, non-compressible binary payloads generated dynamically.
						</p>
						<p class="text-xs md:text-sm text-body leading-relaxed">
							By analyzing the network throughput using six parallel worker threads, this platform runs a true <strong>internet speed test</strong> that stresses the edge. It acts as a comprehensive <strong>netspeed</strong> validator, recording unloaded ping times as well as down-link and up-link loaded latency (bufferbloat). With this level of diagnostic depth, you get a clear network quality score that highlights whether your line is suited for demanding tasks like real-time gaming, VoIP, or video production.
						</p>
					</div>

					<div class="flex flex-col gap-4">
						<h3 class="text-lg font-semibold tracking-tight text-ink font-sans" id="seo-subheading-4">
							How to Get the Most Accurate Results
						</h3>
						<p class="text-xs md:text-sm text-body leading-relaxed">
							To <strong>run speed test</strong> benchmarks effectively and get a reliable <strong>check network speed test</strong> profile:
						</p>
						<ul class="list-decimal pl-5 text-xs md:text-sm text-body flex flex-col gap-1">
							<li><strong>Disconnect VPNs</strong>: Virtual Private Networks route your traffic through secondary servers, increasing latency.</li>
							<li><strong>Limit Active Downloads</strong>: Pause any background downloads or streaming services running on other local devices.</li>
							<li><strong>Use a Wired Connection</strong>: Bypass wireless interference by connecting via an Ethernet cable.</li>
						</ul>
						<p class="text-xs md:text-sm text-body leading-relaxed">
							Regularly performing a <strong>netspeed check</strong> helps you build a performance history. By monitoring these metrics over time, you can quickly identify ISP throttling, router degradation, or regional routing issues, ensuring you always stay connected at peak velocity.
						</p>
					</div>
				</div>

			</div>
		</div>
	</section>

	{/* Professional Footer */}
	<footer class="border-t border-hairline bg-canvas py-8">
		<div
			class="w-full max-w-7xl mx-auto px-4 md:px-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-mono text-mute"
		>
			<div class="flex items-center gap-2">
				<span>© 2026 NetSpeed. Engineered at the Edge.</span>
			</div>
			<div class="flex items-center gap-6">
				<span>NO COMPRESSION</span>
				<span>ZERO BROWSER CACHING</span>
				<span>CONCURRENT PIPES</span>
			</div>
		</div>
	</footer>
</Layout>

<script>
	// Theme toggle setup
	const savedTheme = localStorage.getItem("theme");
	const prefersDark = window.matchMedia(
		"(prefers-color-scheme: dark)",
	).matches;
	const isDark = savedTheme === "dark" || (!savedTheme && prefersDark);

	if (isDark) {
		document.documentElement.classList.add("dark");
	} else {
		document.documentElement.classList.remove("dark");
	}

	const themeToggle = document.getElementById("header-theme-toggle");
	if (themeToggle) {
		themeToggle.addEventListener("click", () => {
			const wasDark = document.documentElement.classList.contains("dark");
			const nextDark = !wasDark;

			if (nextDark) {
				document.documentElement.classList.add("dark");
				localStorage.setItem("theme", "dark");
			} else {
				document.documentElement.classList.remove("dark");
				localStorage.setItem("theme", "light");
			}

			// Broadcast change event to React
			window.dispatchEvent(
				new CustomEvent("theme-changed", {
					detail: { theme: nextDark ? "dark" : "light" },
				}),
			);
		});
	}

	// Server info receiver
	window.addEventListener("server-selected", (e: any) => {
		const textEl = document.getElementById("server-status-text");
		const dotEl = document.getElementById("server-status-dot");
		if (textEl && dotEl) {
			const { name, distance } = e.detail;
			const distStr = distance ? ` (${distance})` : "";

			// Change dot styling to indicate active server
			dotEl.className =
				"w-1.5 h-1.5 rounded-full bg-[#0070f3] animate-pulse";

			// Update location text
			textEl.className = "text-ink font-semibold";
			textEl.textContent = `Server: ${name}${distStr}`;
		}
	});
</script>
