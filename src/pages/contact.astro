---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact Us — NetSpeed Telemetry Support"
  description="Get in touch with the engineering team at NetSpeed. Report routing issues, server outages, or suggest platform optimizations."
>
  <main class="flex-1 py-16 px-4 md:px-8">
    <div class="max-w-xl mx-auto flex flex-col gap-10">
      {/* Page Header */}
      <div class="flex flex-col gap-3 border-b border-hairline pb-6">
        <span class="font-mono text-xs uppercase tracking-wider text-mute block">
          Get in Touch
        </span>
        <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-ink font-sans">
          Contact our team
        </h1>
        <p class="text-sm md:text-base text-body mt-1 leading-relaxed">
          Have feedback, bugs to report, or inquiries about server integrations? Fill out the form below, and our network engineers will review your request.
        </p>
      </div>

      {/* Main Container */}
      <div class="relative min-h-[350px]">
        {/* Contact Form */}
        <form id="contact-form" class="flex flex-col gap-5 transition-opacity duration-300">
          <div class="flex flex-col gap-1.5">
            <label for="name" class="text-xs font-mono text-mute uppercase tracking-wider select-none">
              Your Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="e.g. Alex Rivera"
              class="bg-canvas text-ink border border-hairline hover:border-hairline-strong focus:border-link outline-none text-sm rounded-sm px-4 h-10 w-full transition-all focus:ring-1 focus:ring-link shadow-2xs"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-xs font-mono text-mute uppercase tracking-wider select-none">
              Email Address
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="e.g. alex@example.com"
              class="bg-canvas text-ink border border-hairline hover:border-hairline-strong focus:border-link outline-none text-sm rounded-sm px-4 h-10 w-full transition-all focus:ring-1 focus:ring-link shadow-2xs"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="subject" class="text-xs font-mono text-mute uppercase tracking-wider select-none">
              Subject
            </label>
            <select
              id="subject"
              name="subject"
              required
              class="bg-canvas text-ink border border-hairline hover:border-hairline-strong focus:border-link outline-none text-sm rounded-sm px-4 h-10 w-full transition-all focus:ring-1 focus:ring-link shadow-2xs cursor-pointer"
            >
              <option value="" disabled selected>Select an option</option>
              <option value="issue">Report a Technical Outage / Out-of-bounds Result</option>
              <option value="integration">Partner Server / Edge Integration Proposal</option>
              <option value="feedback">General Interface Feedback & Design Suggestions</option>
              <option value="other">Other Inquiry</option>
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-xs font-mono text-mute uppercase tracking-wider select-none">
              Detailed Message
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Provide context regarding routing paths, device specifications, or server locations..."
              class="bg-canvas text-ink border border-hairline hover:border-hairline-strong focus:border-link outline-none text-sm rounded-sm p-4 w-full transition-all focus:ring-1 focus:ring-link shadow-2xs resize-y min-h-[120px]"
            ></textarea>
          </div>

          <div class="pt-2">
            <button
              type="submit"
              id="submit-button"
              class="w-full bg-primary text-on-primary font-medium text-sm rounded-full py-3 hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2 cursor-pointer shadow-xs select-none"
            >
              Send Message
            </button>
          </div>
        </form>

        {/* Success Feedback View (Hidden initially) */}
        <div
          id="success-view"
          class="hidden absolute inset-0 flex flex-col items-center justify-center text-center p-6 bg-canvas border border-hairline rounded-md shadow-xs opacity-0 scale-95 transition-all duration-300"
        >
          <div class="w-12 h-12 bg-link-bg-soft rounded-full flex items-center justify-center text-link mb-4">
            <svg
              class="w-6 h-6 stroke-current fill-none"
              viewBox="0 0 24 24"
              stroke-width="2.5"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h2 class="text-xl font-semibold tracking-tight text-ink font-sans mb-2">
            Telemetry Message Dispatched
          </h2>
          <p class="text-xs md:text-sm text-body max-w-sm leading-relaxed mb-6">
            Thank you for your report. Our network engineering team receives messages instantly and reviews connection anomalies daily.
          </p>
          <button
            id="reset-button"
            class="bg-canvas text-ink border border-hairline hover:border-hairline-strong font-medium text-xs rounded-full py-2 px-6 active:scale-95 transition-all cursor-pointer select-none"
          >
            Send Another Message
          </button>
        </div>
      </div>
    </div>
  </main>

  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const successView = document.getElementById("success-view");
    const submitBtn = document.getElementById("submit-button") as HTMLButtonElement;
    const resetBtn = document.getElementById("reset-button");

    if (form && successView && submitBtn && resetBtn) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        // Start button transition loading feedback
        submitBtn.disabled = true;
        submitBtn.textContent = "Transmitting telemetry…";
        submitBtn.classList.add("opacity-80");

        const name = (document.getElementById("name") as HTMLInputElement).value;
        const email = (document.getElementById("email") as HTMLInputElement).value;
        const subject = (document.getElementById("subject") as HTMLSelectElement).value;
        const message = (document.getElementById("message") as HTMLTextAreaElement).value;

        try {
          const res = await fetch("/api/contact", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ name, email, subject, message }),
          });

          if (!res.ok) {
            throw new Error("Telemetry transmission failed");
          }

          // Hide form
          form.classList.add("opacity-0", "pointer-events-none");
          
          setTimeout(() => {
            form.classList.add("hidden");
            successView.classList.remove("hidden");
            
            // Force browser layout repaint
            successView.offsetHeight;
            
            // Transition success screen in
            successView.classList.remove("opacity-0", "scale-95");
            successView.classList.add("opacity-100", "scale-100");
          }, 300);
        } catch (err) {
          console.error(err);
          alert("Submission failed. Please check your internet connection and try again.");
          submitBtn.disabled = false;
          submitBtn.textContent = "Send Message";
          submitBtn.classList.remove("opacity-80");
        }
      });

      resetBtn.addEventListener("click", () => {
        // Clear inputs
        form.reset();
        submitBtn.disabled = false;
        submitBtn.textContent = "Send Message";
        submitBtn.classList.remove("opacity-80");

        // Transition out success screen
        successView.classList.remove("opacity-100", "scale-100");
        successView.classList.add("opacity-0", "scale-95");

        setTimeout(() => {
          successView.classList.add("hidden");
          form.classList.remove("hidden");
          
          // Force layout repaint
          form.offsetHeight;
          
          form.classList.remove("opacity-0", "pointer-events-none");
          form.classList.add("opacity-100");
        }, 300);
      });
    }
  </script>
</Layout>
