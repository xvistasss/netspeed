---

---

<footer
  class="border-t border-hairline bg-canvas pt-16 pb-8 px-6 md:px-8 mt-auto relative overflow-hidden"
>
  {/* Subtle atmospheric glow at bottom */}
  <div
    class="absolute top-0 bottom-0 left-0 right-0 bg-gradient-to-b from-mute/[0.13] to-transparent pointer-events-none"
  >
  </div>
  {/* Top decorative gradient line */}
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-hairline-strong/30 to-transparent"
  >
  </div>

  <div class="w-full max-w-7xl mx-auto flex flex-col gap-12 relative">
    {/* Main Content Grid */}
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">
      {/* Brand Column — Wider for emphasis */}
      <div class="flex flex-col gap-5 lg:max-w-sm">
        <a
          href="/"
          class="flex items-center gap-2.5 hover:opacity-90 transition-opacity"
        >
          <img
            src="/favicon.svg"
            alt="NetSpeed Logo"
            width="32"
            height="32"
            class="dark:invert-0"
          />
          <span class="font-bold tracking-tight text-base font-sans text-ink">
            NetSpeed
          </span>
        </a>
        <p class="text-[13px] text-body font-sans leading-relaxed max-w-sm">
          Professional network telemetry engine. Non-compressible binary
          payloads, concurrent streams, and loaded latency measurement — built
          for accuracy, not ads.
        </p>
      </div>

      {/* Navigation Columns */}
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 lg:gap-16 flex-1">
        {/* Product */}
        <div class="flex flex-col">
          <span
            class="font-mono text-[10px] uppercase tracking-widest text-mute mb-4 block"
          >
            Product
          </span>
          <ul class="flex flex-col gap-2.5">
            <li>
              <a
                href="/"
                class="text-[13px] text-body hover:text-ink transition-colors duration-150 font-sans"
              >
                Speed Test
              </a>
            </li>
            <li>
              <a
                href="/#faq-section"
                class="text-[13px] text-body hover:text-ink transition-colors duration-150 font-sans"
              >
                FAQ
              </a>
            </li>
            <li>
              <a
                href="/about"
                class="text-[13px] text-body hover:text-ink transition-colors duration-150 font-sans"
              >
                About
              </a>
            </li>
          </ul>
        </div>

        {/* Resources */}
        <div class="flex flex-col">
          <span
            class="font-mono text-[10px] uppercase tracking-widest text-mute mb-4 block"
          >
            Resources
          </span>
          <ul class="flex flex-col gap-2.5">
            <li>
              <a
                href="https://github.com/xvistasss/netspeed"
                target="_blank"
                rel="noopener noreferrer"
                class="text-[13px] text-body hover:text-ink transition-colors duration-150 font-sans inline-flex items-center gap-1.5"
              >
                GitHub
                <svg
                  class="w-3 h-3 text-mute"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M7 17L17 7"></path>
                  <path d="M7 7h10v10"></path>
                </svg>
              </a>
            </li>
            <li>
              <a
                href="/contact"
                class="text-[13px] text-body hover:text-ink transition-colors duration-150 font-sans"
              >
                Contact
              </a>
            </li>
          </ul>
        </div>

        {/* Legal */}
        <div class="flex flex-col">
          <span
            class="font-mono text-[10px] uppercase tracking-widest text-mute mb-4 block"
          >
            Legal
          </span>
          <ul class="flex flex-col gap-2.5">
            <li>
              <a
                href="/privacy"
                class="text-[13px] text-body hover:text-ink transition-colors duration-150 font-sans"
              >
                Privacy
              </a>
            </li>
            <li>
              <a
                href="/terms"
                class="text-[13px] text-body hover:text-ink transition-colors duration-150 font-sans"
              >
                Terms
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    {/* Bottom Bar */}
    <div class="border-t border-hairline pt-6 mb-6">
      {/* Copyright + Creator */}
      <div
        class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-[11px] font-mono text-mute"
      >
        <span
          >&copy; {new Date().getFullYear()} NetSpeed. Crafted with ❤️ by
          <a
            href="https://apurba-dev.netlify.app/"
            target="_blank"
            class="text-body hover:text-ink transition-colors duration-150 underline underline-offset-2 decoration-hairline hover:decoration-body"
            >Apurba</a
          >, Assam, India.</span
        >
      </div>
    </div>
  </div>
</footer>
