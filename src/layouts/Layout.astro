---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  showServerStatus?: boolean;
  showMeshGradient?: boolean;
}
const {
  title = "Network Speed Test — NetSpeed Professional Internet Speed Test",
  description = "Run a highly accurate network speed test tool to check your internet download, upload, and latency speeds via optimal server selection. Clean, ads-free, and professional.",
  showServerStatus = false,
  showMeshGradient = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap.xml" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Canonical URL -->
    <link rel="canonical" href={Astro.url} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/og-image.png", Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta
      property="twitter:image"
      content={new URL("/og-image.png", Astro.url)}
    />
    <!-- Fonts are self-hosted via @font-face in global.css -->

    <!-- Inline theme initialization via localStorage — synchronous, no FOUC -->
    <script is:inline>
      (function () {
        var savedTheme = localStorage.getItem("theme");
        var prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        if (savedTheme === "dark" || (!savedTheme && prefersDark)) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
  </head>
  <body
    class="bg-canvas-soft text-ink font-sans antialiased min-h-screen relative"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:top-2 focus:left-2 focus:bg-primary focus:text-on-primary focus:px-3 focus:py-1.5 focus:rounded focus:text-sm focus:font-medium"
    >
      Skip to content
    </a>
    <!-- Mesh gradient overlay — homepage only for GPU savings -->
    {
      showMeshGradient && (
        <div class="mesh-gradient-container">
          <div class="mesh-gradient" />
        </div>
      )
    }
    <div class="relative z-10 flex flex-col min-h-screen">
      <Header showServerStatus={showServerStatus} />
      <main id="main-content" class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      // Theme toggle setup on page load
      const setupThemeToggle = () => {
        const themeToggle = document.getElementById("header-theme-toggle");
        if (themeToggle) {
          themeToggle.addEventListener("click", () => {
            const wasDark = document.documentElement.classList.contains("dark");
            const nextDark = !wasDark;

            if (nextDark) {
              document.documentElement.classList.add("dark");
            } else {
              document.documentElement.classList.remove("dark");
            }

            // Persist in localStorage - enables synchronous FOUC prevention
            const themeValue = nextDark ? "dark" : "light";
            localStorage.setItem("theme", themeValue);

            // Broadcast change event to React
            window.dispatchEvent(
              new CustomEvent("theme-changed", {
                detail: { theme: themeValue },
              }),
            );
          });
        }
      };

      setupThemeToggle();
      document.addEventListener("astro:after-swap", setupThemeToggle);

      const setupTerminalToggle = () => {
        const terminalToggle = document.getElementById(
          "header-terminal-toggle",
        );
        if (terminalToggle) {
          // Seed localStorage on first visit so script and React agree on the default
          if (localStorage.getItem("terminal-open") === null) {
            localStorage.setItem("terminal-open", "false");
          }

          const isOpen = localStorage.getItem("terminal-open") === "true";
          terminalToggle.classList.toggle("bg-canvas-soft-2", isOpen);
          terminalToggle.classList.toggle("text-ink", isOpen);
          terminalToggle.classList.toggle("border-primary", isOpen);
          terminalToggle.classList.toggle("text-primary", isOpen);

          terminalToggle.addEventListener("click", () => {
            const currentlyOpen =
              localStorage.getItem("terminal-open") === "true";
            const nextOpen = !currentlyOpen;
            localStorage.setItem("terminal-open", String(nextOpen));

            // Update button visual state
            terminalToggle.classList.toggle("bg-canvas-soft-2", nextOpen);
            terminalToggle.classList.toggle("text-ink", nextOpen);
            terminalToggle.classList.toggle("border-primary", nextOpen);
            terminalToggle.classList.toggle("text-primary", nextOpen);

            window.dispatchEvent(
              new CustomEvent("toggle-terminal", {
                detail: { open: nextOpen },
              }),
            );
          });
        }
      };

      setupTerminalToggle();
      document.addEventListener("astro:after-swap", setupTerminalToggle);
    </script>
  </body>
</html>
