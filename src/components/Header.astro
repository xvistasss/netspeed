---
interface Props {
  showServerStatus?: boolean;
}

const { showServerStatus = false } = Astro.props;
---

<header
  class="sticky top-0 bg-canvas/80 backdrop-blur-md border-b border-hairline h-14 md:h-16 flex items-center z-50"
>
  <div
    class="w-full max-w-7xl mx-auto px-4 md:px-8 flex items-center justify-between gap-2 md:gap-4"
  >
    <!-- Left: Logo + Brand + Version Badge -->
    <div class="flex items-center gap-3 min-w-0">
      <a
        href="/"
        class="flex items-center gap-2.5 hover:opacity-90 transition-opacity shrink-0"
      >
        <img
          src="/favicon.svg"
          alt="NetSpeed Logo"
          width="32"
          height="32"
          class="md:w-10 md:h-10 dark:invert-0 shrink-0"
        />
        <span
          class="font-bold tracking-tight text-sm font-sans text-ink leading-tight"
        >
          NetSpeed
        </span>
      </a>
      <nav class="hidden md:block">
        <span
          class="text-xs font-mono bg-canvas-soft-2 px-2.5 py-1 rounded border border-hairline text-mute"
        >
          v1.0.0-edge
        </span>
      </nav>
    </div>

    <!-- Right: Server Status + Theme Toggle -->
    <div class="flex items-center gap-1.5 md:gap-3 shrink-0">
      {
        showServerStatus && (
          <div
            class="flex items-center gap-1.5 text-xs font-mono text-mute select-none min-w-0 max-w-[100px] sm:max-w-[180px] md:max-w-[260px] lg:max-w-[400px]"
          >
            <span class="server-status-dot w-1.5 h-1.5 rounded-full bg-mute animate-pulse shrink-0" />
            <span
              id="header-server-text"
              class="truncate bg-transparent text-mute border-none text-xs font-mono hidden sm:inline"
            >
              Auto: Detecting…
            </span>
          </div>
        )
      }
      <button
        id="header-theme-toggle"
        class="min-w-[44px] min-h-[44px] w-8 h-8 md:w-9 md:h-9 rounded-full border border-hairline bg-canvas hover:bg-canvas-soft hover:text-ink text-mute active:scale-95 transition-all shadow-xs flex items-center justify-center cursor-pointer select-none"
        title="Switch Theme"
        aria-label="Toggle dark mode"
      >
        <!-- Sun icon for light mode (hidden in dark mode) -->
        <svg
          id="sun-icon"
          class="w-3.5 h-3.5 md:w-4 md:h-4 fill-none stroke-current block dark:hidden"
          viewBox="0 0 24 24"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"
          ></path>
        </svg>
        {/* Moon icon for dark mode (hidden in light mode) */}
        <svg
          id="moon-icon"
          class="w-3.5 h-3.5 md:w-4 md:h-4 fill-none stroke-current hidden dark:block"
          viewBox="0 0 24 24"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const serverText = document.getElementById(
    "header-server-text",
  ) as HTMLSpanElement | null;
  const statusDots = document.querySelectorAll(".server-status-dot");

  window.addEventListener("servers-discovered", (e: any) => {
    const { servers } = e.detail;
    if (!serverText) return;

    const first =
      Array.isArray(servers) && servers.length > 0 ? servers[0] : null;
    if (!first) {
      serverText.textContent = "Server: Auto Detecting…";
      return;
    }

    const distStr = first.distance ? ` (${first.distance})` : "";
    serverText.textContent = `Server (Auto): ${first.name}${distStr}`;
  });

  window.addEventListener("server-selected", (e: any) => {
    const { name, distance, latency } = e.detail;

    const distStr = distance ? ` (${distance})` : "";
    const latStr =
      latency !== undefined && latency > 0 ? ` [${Math.round(latency)}ms]` : "";

    statusDots.forEach((dot) => {
      dot.className =
        "server-status-dot w-1.5 h-1.5 rounded-full bg-[#0070f3] animate-pulse shrink-0";
    });

    if (serverText) {
      serverText.textContent = `Server (Auto): ${name}${distStr}${latStr}`;
    }
  });
</script>
