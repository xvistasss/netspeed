---

---

<footer
  class="border-t border-hairline bg-canvas py-16 px-6 md:px-8 mt-auto relative overflow-hidden"
>
  {/* Subtle decorative bottom gradient line to make it look premium */}
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-3/4 h-[1px] bg-gradient-to-r from-transparent via-hairline-strong/20 to-transparent"
  >
  </div>

  <div class="w-full max-w-7xl mx-auto flex flex-col gap-12">
    <div
      class="flex flex-col md:flex-row items-stretch md:justify-between gap-8"
    >
      {/* Brand Column */}
      <div class="flex flex-col gap-4 lg:col-span-1">
        <a
          href="/"
          class="flex items-center gap-2 hover:opacity-90 transition-opacity"
        >
          <img
            src="/favicon.svg"
            alt="NetSpeed Logo"
            width="32"
            height="32"
            class="dark:invert-0"
          />
          <span class="font-bold tracking-tight text-sm font-sans text-ink"
            >NetSpeed</span
          >
        </a>
        <p class="text-xs text-body font-sans leading-relaxed max-w-xs">
          High-fidelity, edge-native telemetry. Offering uncompromised
          connection metrics free from ISP traffic compression or browser
          caching distortion.
        </p>
        <div
          class="flex items-center gap-2 mt-2 text-[10px] font-mono text-body bg-canvas-soft border border-hairline px-3 py-1 rounded-full w-fit"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"
          ></span>
          <span>Edge Nodes Operational</span>
        </div>
      </div>

      {/* Grid Section */}
      <div class="grid grid-cols-3 gap-8 lg:gap-12">
        {/* Company Column */}
        <div class="flex flex-col">
          <span
            class="font-mono text-[11px] uppercase tracking-wider text-mute mb-4 block"
          >
            Company
          </span>
          <ul class="flex flex-col gap-2.5">
            <li>
              <a
                href="/about"
                class="text-sm text-body hover:text-ink transition-colors font-sans"
              >
                About Us
              </a>
            </li>
            <li>
              <a
                href="/contact"
                class="text-sm text-body hover:text-ink transition-colors font-sans"
              >
                Contact Us
              </a>
            </li>
          </ul>
        </div>

        {/* Resources Column */}
        <div class="flex flex-col">
          <span
            class="font-mono text-[11px] uppercase tracking-wider text-mute mb-4 block"
          >
            Resources
          </span>
          <ul class="flex flex-col gap-2.5">
            <li>
              <a
                href="/#faq-section"
                class="text-sm text-body hover:text-ink transition-colors font-sans"
              >
                FAQ & Support
              </a>
            </li>
            <li>
              <a
                href="https://github.com/xvistasss/netspeed"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-body hover:text-ink transition-colors font-sans"
              >
                GitHub Repo
              </a>
            </li>
          </ul>
        </div>

        {/* Legal Column */}
        <div class="flex flex-col">
          <span
            class="font-mono text-[11px] uppercase tracking-wider text-mute mb-4 block"
          >
            Legal
          </span>
          <ul class="flex flex-col gap-2.5">
            <li>
              <a
                href="/privacy"
                class="text-sm text-body hover:text-ink transition-colors font-sans"
              >
                Privacy Policy
              </a>
            </li>
            <li>
              <a
                href="/terms"
                class="text-sm text-body hover:text-ink transition-colors font-sans"
              >
                Terms & Conditions
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    {/* Divider */}
    <div class="w-full h-px bg-hairline"></div>

    {/* Bottom Footer Section: Telemetry & Copyright */}
    <div
      class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 text-xs font-mono text-mute"
    >
      <div class="flex flex-col gap-1">
        <span>© 2026 NetSpeed Inc. All rights reserved.</span>
        <span class="text-[10px] text-mute"
          >Engineered at the edge for maximum telemetry resolution.</span
        >
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <span
          class="px-2 py-0.5 bg-canvas-soft-2 text-[10px] font-mono border border-hairline rounded text-mute tracking-wider uppercase"
        >
          No Compression
        </span>
        <span
          class="px-2 py-0.5 bg-canvas-soft-2 text-[10px] font-mono border border-hairline rounded text-mute tracking-wider uppercase"
        >
          Zero Caching
        </span>
        <span
          class="px-2 py-0.5 bg-canvas-soft-2 text-[10px] font-mono border border-hairline rounded text-mute tracking-wider uppercase"
        >
          Concurrent Pipes
        </span>
      </div>
    </div>
  </div>
</footer>
